{
  "services": {
    "send_command": {
      "name": "Send command",
      "description": "Sends a raw command to the receiver and returns any reply lines. Useful for testing commands that the integration does not expose.",
      "fields": {
        "command": {
          "name": "Command",
          "description": "The raw Pioneer command to send, without the carriage return (e.g. ?P, PO, 05FN)."
        },
        "timeout": {
          "name": "Timeout",
          "description": "How long to wait for reply lines, in seconds."
        }
      }
    }
  },
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "user": {
        "data": {
          "device": "[%key:common::config_flow::data::port%]"
        },
        "data_description": {
          "device": "Serial port the receiver is connected to"
        }
      }
    }
  },
  "entity": {
    "media_player": {
      "receiver": {
        "state_attributes": {
          "source": {
            "state": {
              "phono": "Phono",
              "cd": "CD",
              "tuner": "Tuner",
              "cdr": "CD-R",
              "dvd": "DVD",
              "tv": "TV",
              "video_1": "Video 1",
              "video_2": "Video 2",
              "multi_ch": "Multi Channel In",
              "dvr_1": "DVR/BDR 1",
              "dvr_2": "DVR/BDR 2",
              "ipod": "iPod",
              "xm": "XM",
              "hdmi_1": "HDMI 1",
              "hdmi_2": "HDMI 2",
              "hdmi_3": "HDMI 3",
              "bdp": "BD Player",
              "sirius": "SiriusXM",
              "hdmi_cyclic": "HDMI (cyclic)"
            }
          }
        }
      }
    },
    "sensor": {
      "audio_format": {
        "name": "Audio format"
      }
    },
    "switch": {
      "tone": {
        "name": "Tone control"
      }
    },
    "number": {
      "bass": {
        "name": "Bass"
      },
      "treble": {
        "name": "Treble"
      }
    },
    "select": {
      "phase_control": {
        "name": "Phase control",
        "state": {
          "off": "Off",
          "on": "On",
          "full_band": "Full band phase control"
        }
      },
      "sb_processing": {
        "name": "Surround back processing",
        "state": {
          "off": "Off",
          "on": "On",
          "auto": "Auto"
        }
      },
      "mcacc": {
        "name": "MCACC memory",
        "state": {
          "off": "Off",
          "memory_1": "Memory 1",
          "memory_2": "Memory 2",
          "memory_3": "Memory 3",
          "memory_4": "Memory 4",
          "memory_5": "Memory 5",
          "memory_6": "Memory 6"
        }
      }
    }
  }
}
